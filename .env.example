# Application
APP_NAME="URL Shortener"
BASE_URL=http://localhost:8000
LOG_LEVEL=INFO

# Database (CockroachDB)
DATABASE_URL=cockroachdb+psycopg2://root@localhost:26257/urlshortener?sslmode=disable

# Cache (DragonflyDB — Redis-compatible, same port 6379)
DRAGONFLY_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60